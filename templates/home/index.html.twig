{# templates/ticket/index.html.twig #}
<a href="{{ path('app_ticket_new') }}" class="btn btn-success mb-3">
    <i class="bi bi-plus-circle"></i> Nouveau ticket
</a>

<table class="table">
  <thead>
    <tr>
      <th>Titre</th><th>Priorité</th><th>Statut</th>
    </tr>
  </thead>
  <tbody>
  {% for ticket in tickets %}
    <tr>
      <td>{{ ticket.titre }}</td>

      <td>
        <span class="badge {{ ticket.priorite.badgeClass() }}">
          {{ ticket.priorite.value }}
        </span>
      </td>

      <td>
        <span class="badge {{ ticket.statut.badgeClass() }}">
          {{ ticket.statut.value }}
        </span>
      </td>
    </tr>
  {% endfor %}
  </tbody>
</table>
